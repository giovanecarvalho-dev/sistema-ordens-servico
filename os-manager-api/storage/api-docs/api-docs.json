{
    "openapi": "3.0.0",
    "info": {
        "title": "OS Manager API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Servidor Local"
        }
    ],
    "paths": {
        "/api/dashboard/estatisticas": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Retorna dados estatísticos do sistema",
                "description": "Acesso restrito: Apenas usuários com cargo de Admin podem visualizar as estatísticas.",
                "operationId": "280207991833169165fa89055b977585",
                "responses": {
                    "200": {
                        "description": "Estatísticas geradas com sucesso"
                    },
                    "403": {
                        "description": "Acesso negado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/ordens": {
            "get": {
                "tags": [
                    "OrdensServico"
                ],
                "summary": "Lista e filtra as ordens de serviço",
                "description": "Acesso para Técnicos e Admins. Filtro por ID ou Status de Ativação.",
                "operationId": "e9954d9a37630cdf929ae616b77d4103",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "ativo",
                        "in": "query",
                        "schema": {
                            "type": "boolean"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de OS encontrada"
                    },
                    "403": {
                        "description": "Acesso negado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "OrdensServico"
                ],
                "summary": "Cria uma nova ordem de serviço",
                "operationId": "57a9b14a3f752b7e724fb3443663c8e5",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "titulo",
                                    "descricao",
                                    "usuario_id",
                                    "localizacao"
                                ],
                                "properties": {
                                    "titulo": {
                                        "type": "string",
                                        "example": "Troca de toner"
                                    },
                                    "descricao": {
                                        "type": "string",
                                        "example": "Impressora do RH sem tinta"
                                    },
                                    "usuario_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "categoria": {
                                        "type": "string",
                                        "enum": [
                                            "Rede",
                                            "Infraestrutura",
                                            "Acesso"
                                        ],
                                        "example": "Rede"
                                    },
                                    "localizacao": {
                                        "type": "string",
                                        "example": "Bloco A - Sala 10"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Ordem criada com sucesso"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/ordens/{id}": {
            "get": {
                "tags": [
                    "OrdensServico"
                ],
                "summary": "Mostra detalhes de uma ordem",
                "operationId": "47855ee63438258517219d38894ca714",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ordem encontrada"
                    },
                    "404": {
                        "description": "Ordem não encontrada"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "OrdensServico"
                ],
                "summary": "Atualiza uma ordem",
                "operationId": "a5d619b2ba267041732114d8f319a67f",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "Novo",
                                            "Em andamento",
                                            "Fechado"
                                        ],
                                        "example": "Em andamento"
                                    },
                                    "urgencia": {
                                        "type": "string",
                                        "enum": [
                                            "Baixa",
                                            "Média",
                                            "Alta",
                                            "Muito Alta"
                                        ],
                                        "example": "Alta"
                                    },
                                    "prioridade": {
                                        "type": "string",
                                        "enum": [
                                            "Baixa",
                                            "Média",
                                            "Alta",
                                            "Muito Alta"
                                        ],
                                        "example": "Alta"
                                    },
                                    "tecnico_id": {
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "solucao": {
                                        "type": "string",
                                        "example": "Problema resolvido"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Ordem atualizada"
                    },
                    "404": {
                        "description": "Ordem não encontrada"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "OrdensServico"
                ],
                "summary": "Remove uma ordem (Manda para lixeira)",
                "operationId": "3ddb628fff4f4f9ebafbcbbc20f22bd1",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ordem removida"
                    },
                    "404": {
                        "description": "Ordem não encontrada"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/ordens/{id}/restaurar": {
            "put": {
                "tags": [
                    "OrdensServico"
                ],
                "summary": "Restaura uma ordem inativa (Apenas Admin)",
                "description": "Muda o campo ativo de false para true.",
                "operationId": "ffc106dcbc654bc794e51f10ed595e74",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ordem restaurada"
                    },
                    "403": {
                        "description": "Acesso negado"
                    },
                    "404": {
                        "description": "Ordem não encontrada"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/usuarios": {
            "get": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Lista e filtra usuários",
                "operationId": "e9d4d8b419dbef04b5748fbf9ccf3881",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "Filtrar por ID",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "ativo",
                        "in": "query",
                        "description": "Filtrar por status",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sucesso"
                    },
                    "403": {
                        "description": "Acesso negado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Cria um novo usuário",
                "operationId": "4e9dbcbdaaaf9faab196a82d5cbaea23",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "nome": {
                                        "type": "string",
                                        "example": "João Silva"
                                    },
                                    "cpf": {
                                        "type": "string",
                                        "example": "12345678901"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "joao@email.com"
                                    },
                                    "senha": {
                                        "type": "string",
                                        "example": "1234"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuário criado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Login do usuário",
                "operationId": "97e61fbe879f3468ebf503966c2d3482",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "cpf": {
                                        "type": "string",
                                        "example": "12345678901"
                                    },
                                    "senha": {
                                        "type": "string",
                                        "example": "1234"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login realizado"
                    },
                    "401": {
                        "description": "Credenciais inválidas"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Logout do usuário",
                "operationId": "0a34c472396743ed286587cbadd19d6f",
                "responses": {
                    "200": {
                        "description": "Logout realizado"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/usuarios/{id}": {
            "put": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Atualiza o cargo de um usuário",
                "operationId": "27ac608b6dd8b8e7c7c45b10c5210b3e",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "cargo"
                                ],
                                "properties": {
                                    "cargo": {
                                        "type": "string",
                                        "enum": [
                                            "Usuario",
                                            "Tecnico",
                                            "Admin"
                                        ],
                                        "example": "Tecnico"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Cargo atualizado"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Remove um usuário",
                "operationId": "ea700764859a665afd38bb39c2842f1c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Usuário removido"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/usuarios/{id}/perfil": {
            "put": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Atualiza perfil do usuário logado",
                "operationId": "d6671a7b6025820d3fc8f3f29159cc2c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nome",
                                    "email"
                                ],
                                "properties": {
                                    "nome": {
                                        "type": "string",
                                        "example": "João Silva"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "joao@email.com"
                                    },
                                    "senha_atual": {
                                        "type": "string",
                                        "example": "1234"
                                    },
                                    "nova_senha": {
                                        "type": "string",
                                        "example": "4321"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Perfil atualizado"
                    },
                    "400": {
                        "description": "Senha atual incorreta"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "OrdensServico",
            "description": "Endpoints para gerenciamento de ordens de serviço"
        },
        {
            "name": "Usuarios",
            "description": "Endpoints para gerenciamento de usuários"
        },
        {
            "name": "Dashboard",
            "description": "Dashboard"
        }
    ]
}