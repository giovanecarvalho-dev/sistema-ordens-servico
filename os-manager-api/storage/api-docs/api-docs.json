{
    "openapi": "3.0.0",
    "info": {
        "title": "OS Manager API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Servidor Local"
        }
    ],
    "paths": {
        "/api/dashboard/estatisticas": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Retorna dados estatísticos do sistema",
                "description": "Acesso restrito: Apenas usuários com permissão 'dashboard.visualizar' ou cargo Admin.",
                "operationId": "280207991833169165fa89055b977585",
                "responses": {
                    "200": {
                        "description": "Estatísticas geradas com sucesso"
                    },
                    "403": {
                        "description": "Acesso negado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/ordens": {
            "get": {
                "tags": [
                    "Ordens de Servico"
                ],
                "summary": "Lista todas as ordens de serviço com filtros",
                "operationId": "e9954d9a37630cdf929ae616b77d4103",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filtrar por nome do status",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "categoria",
                        "in": "query",
                        "description": "Filtrar por nome da categoria",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "busca",
                        "in": "query",
                        "description": "Busca por título ou descrição",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "ID",
                        "in": "query",
                        "description": "Filtrar por ID numérico ou código de rastreio (UUID)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de ordens recuperada com sucesso"
                    },
                    "401": {
                        "description": "Não autenticado"
                    },
                    "404": {
                        "description": "Ordens de serviço não encontradas"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Ordens de Servico"
                ],
                "summary": "Cria uma nova ordem de serviço",
                "operationId": "57a9b14a3f752b7e724fb3443663c8e5",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "titulo": {
                                        "type": "string",
                                        "example": "Estagiário esqueceu a senha"
                                    },
                                    "descricao": {
                                        "type": "string",
                                        "example": "O estagiário João da Silva esqueceu a senha do sistema e precisa de ajuda para resetar o acesso."
                                    },
                                    "localizacao": {
                                        "type": "string",
                                        "example": "Bloco A, Sala 102"
                                    },
                                    "categoria": {
                                        "type": "string",
                                        "example": "Acesso"
                                    },
                                    "urgencia": {
                                        "type": "string",
                                        "example": "Alta"
                                    },
                                    "prioridade": {
                                        "type": "string",
                                        "example": "Muito Alta"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Ordem de serviço criada com sucesso"
                    },
                    "422": {
                        "description": "Erro de validação nos dados enviados"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/ordens/{id}": {
            "get": {
                "tags": [
                    "Ordens de Servico"
                ],
                "summary": "Exibe detalhes de uma ordem de serviço específica",
                "description": "Busca uma Ordem de Serviço pelo ID numérico ou pelo Código de Rastreio (UUID)",
                "operationId": "47855ee63438258517219d38894ca714",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID numérico ou Código de Rastreio (UUID)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Dados da ordem de serviço"
                    },
                    "401": {
                        "description": "Não autenticado"
                    },
                    "404": {
                        "description": "Ordem de serviço não encontrada"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Ordens de Servico"
                ],
                "summary": "Atualiza uma ordem de serviço",
                "operationId": "a5d619b2ba267041732114d8f319a67f",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ordem de serviço atualizada"
                    },
                    "403": {
                        "description": "Acesso negado"
                    },
                    "404": {
                        "description": "Ordem de serviço não encontrada"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Ordens de Servico"
                ],
                "summary": "Remove (desativa) uma ordem de serviço",
                "operationId": "3ddb628fff4f4f9ebafbcbbc20f22bd1",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ordem de serviço removida"
                    },
                    "403": {
                        "description": "Acesso negado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/usuarios": {
            "get": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Lista usuários com filtros, paginação e contagem de ordens",
                "operationId": "e9d4d8b419dbef04b5748fbf9ccf3881",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "Filtrar por ID específico",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "ativo",
                        "in": "query",
                        "description": "Filtrar por status ativo/inativo",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "nome",
                        "in": "query",
                        "description": "Buscar por parte do nome",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Buscar por e-mail",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "cpf",
                        "in": "query",
                        "description": "Buscar por início do CPF",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "cargo",
                        "in": "query",
                        "description": "Filtrar pelo nome do cargo (ex: Admin, Tecnico, Usuario)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "busca",
                        "in": "query",
                        "description": "Busca global (nome, email ou cpf)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Número da página (padrão: 1)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Itens por página (padrão: 15, máximo: 100)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista paginada de usuários"
                    },
                    "401": {
                        "description": "Não autenticado"
                    },
                    "403": {
                        "description": "Acesso negado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Cria um novo usuário",
                "operationId": "4e9dbcbdaaaf9faab196a82d5cbaea23",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "nome": {
                                        "type": "string",
                                        "example": "João Silva"
                                    },
                                    "cpf": {
                                        "type": "string",
                                        "example": "12345678901"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "joao@email.com"
                                    },
                                    "senha": {
                                        "type": "string",
                                        "example": "1234"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuário criado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Login do usuário",
                "operationId": "97e61fbe879f3468ebf503966c2d3482",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "cpf": {
                                        "type": "string",
                                        "example": "12345678901"
                                    },
                                    "senha": {
                                        "type": "string",
                                        "example": "1234"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login realizado"
                    },
                    "401": {
                        "description": "Credenciais inválidas"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Logout do usuário",
                "operationId": "0a34c472396743ed286587cbadd19d6f",
                "responses": {
                    "200": {
                        "description": "Logout realizado"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/usuarios/{id}": {
            "put": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Atualiza o cargo de um usuário",
                "operationId": "27ac608b6dd8b8e7c7c45b10c5210b3e",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "cargo"
                                ],
                                "properties": {
                                    "cargo": {
                                        "type": "string",
                                        "enum": [
                                            "Usuario",
                                            "Tecnico",
                                            "Admin"
                                        ],
                                        "example": "Tecnico"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Cargo atualizado"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Remove um usuário",
                "operationId": "ea700764859a665afd38bb39c2842f1c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Usuário removido"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/perfil": {
            "get": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Retorna os dados do usuário logado atual",
                "operationId": "23d1158de28b035c859ac04071c13dcb",
                "responses": {
                    "200": {
                        "description": "Dados do usuário logado"
                    },
                    "401": {
                        "description": "Não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/usuarios/{id}/perfil": {
            "put": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Atualiza perfil do usuário logado",
                "operationId": "d6671a7b6025820d3fc8f3f29159cc2c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nome",
                                    "email"
                                ],
                                "properties": {
                                    "nome": {
                                        "type": "string",
                                        "example": "João Silva"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "joao@email.com"
                                    },
                                    "senha_atual": {
                                        "type": "string",
                                        "example": "1234"
                                    },
                                    "nova_senha": {
                                        "type": "string",
                                        "example": "4321"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Perfil atualizado"
                    },
                    "400": {
                        "description": "Senha atual incorreta"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Usuarios",
            "description": "Endpoints para gerenciamento de usuários"
        },
        {
            "name": "Dashboard",
            "description": "Dashboard"
        },
        {
            "name": "Ordens de Servico",
            "description": "Ordens de Servico"
        }
    ]
}