                    },
                    "404": {
                        "description": "Ordem de serviço ou anexo não encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/ordens/{id}/comentarios": {
            "post": {
                "tags": [
                    "Ordens de Serviço"
                ],
                "summary": "Adicionar Comentário",
                "description": "Adiciona um novo comentário a uma ordem de serviço. Apenas o criador, técnico responsável ou Admin podem comentar.",
                "operationId": "d9726138f4f972f7c9db3e1a7e04f4f0",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID numérico ou Código de Rastreio (UUID) da OS",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "conteudo"
                                ],
                                "properties": {
                                    "conteudo": {
                                        "description": "Conteúdo do comentário (máx 1000 chars)",
                                        "type": "string"
                                    },
                                    "parent_id": {
                                        "description": "ID do comentário pai (para respostas)",
                                        "type": "integer",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Comentário adicionado com sucesso"
                    },
                    "401": {
                        "description": "Não autenticado"
                    },
                    "403": {
                        "description": "Acesso negado"
                    },
                    "404": {
                        "description": "Ordem de serviço não encontrada"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/ordens/{id}/comentarios/{comentarioId}": {
            "put": {
                "tags": [
                    "Ordens de Serviço"
                ],
                "summary": "Editar Comentário",
                "description": "Edita um comentário existente. Usuários comuns só podem editar seus próprios comentários dentro de 5 minutos. Admin não tem limite de tempo.",
                "operationId": "b5deeaa577e3938799ac864b63e5ccf0",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID numérico ou Código de Rastreio (UUID) da OS",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "comentarioId",
                        "in": "path",
                        "description": "ID do comentário",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "conteudo"
                                ],
                                "properties": {
                                    "conteudo": {
                                        "description": "Novo conteúdo (máx 1000 chars)",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Comentário editado com sucesso"
                    },
                    "401": {
                        "description": "Não autenticado"
                    },
                    "403": {
                        "description": "Acesso negado / Tempo limite expirado"
                    },
                    "404": {
                        "description": "Comentário não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Ordens de Serviço"
                ],
                "summary": "Excluir Comentário",
                "description": "Exclui um comentário. Pode ser excluído apenas para o usuário atual ou para todos (deleção lógica). Apenas o autor ou Admin podem excluir.",
                "operationId": "161cf2774485ba120987c2de648418c4",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID numérico ou Código de Rastreio (UUID) da OS",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "comentarioId",
                        "in": "path",
                        "description": "ID do comentário",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tipo"
                                ],
                                "properties": {
                                    "tipo": {
                                        "description": "Tipo de exclusão: 'mim' ou 'todos'",
                                        "type": "string",
                                        "enum": [
                                            "mim",
                                            "todos"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Comentário excluído com sucesso"
                    },
                    "401": {
                        "description": "Não autenticado"
                    },
                    "403": {
                        "description": "Acesso negado"
                    },
                    "404": {
                        "description": "Comentário não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/usuarios": {
            "get": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Lista usuários com filtros, paginação e contagem de ordens",
                "operationId": "e9d4d8b419dbef04b5748fbf9ccf3881",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "Filtrar por ID específico",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "ativo",
                        "in": "query",
                        "description": "Filtrar por status ativo/inativo",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "nome",
                        "in": "query",
                        "description": "Buscar por parte do nome",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Buscar por e-mail",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "cpf",
                        "in": "query",
                        "description": "Buscar por início do CPF",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "cargo",
                        "in": "query",
                        "description": "Filtrar pelo nome do cargo (ex: Admin, Tecnico, Usuario)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "busca",
                        "in": "query",
                        "description": "Busca global (nome, email ou cpf)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Número da página (padrão: 1)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Itens por página (padrão: 15, máximo: 100)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista paginada de usuários"
